[2026-05-05T20:07:29.803+0000] {subprocess.py:75} INFO - Running command: ['/usr/bin/bash', '-c', '\n            python3 -c "\nimport json, os\n\nsources = [\'jumia_ma\', \'avito_ma\', \'amazon_ma\', \'electroplanet_ma\']\ncleaned = []\nfor src in sources:\n    path = f\'/opt/***/data/raw/{src}.json\'\n    if not os.path.exists(path):\n        continue\n    data = json.load(open(path))\n    for p in data:\n        price = p.get(\'price\', 0)\n        name  = str(p.get(\'name\', \'\')).strip()\n        if price and price > 0 and name:\n            discount_str = str(p.get(\'discount\',\'0%\')).replace(\'%\',\'\')\n            try:\n                disc = float(discount_str)\n            except:\n                disc = 0.0\n            cleaned.append({\n                \'name\'        : name,\n                \'price\'       : float(price),\n                \'old_price\'   : float(p.get(\'old_price\') or price),\n                \'discount_pct\': round(disc, 2),\n                \'rating\'      : str(p.get(\'rating\',\'\')),\n                \'currency\'    : str(p.get(\'currency\',\'MAD\')),\n                \'category\'    : str(p.get(\'category\',\'\')).strip(),\n                \'source\'      : str(p.get(\'source\',\'\')),\n                \'scraped_at\'  : str(p.get(\'scraped_at\',\'\')),\n            })\n\nos.makedirs(\'/opt/***/data/cleaned\', exist_ok=True)\njson.dump(cleaned, open(\'/opt/***/data/cleaned/products_cleaned.json\',\'w\'), ensure_ascii=False)\nprint(f\'✅ {len(cleaned)} produits nettoyés → /data/cleaned/products_cleaned.json\')\n"\n        ']
